<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ page_description | escape_attr }}">
  <meta property="og:title" content="{{ page_title | escape_attr }}">
  <meta property="og:description" content="{{ page_description | escape_attr }}">
  <meta property="og:url" content="{{ canonical_url | escape_attr }}">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape_attr }}">
  <meta name="twitter:description" content="{{ page_description | escape_attr }}">
  {% if product and product.coverImage %}
    <meta property="og:image" content="{{ product.coverImage.url | escape_attr }}">
    <meta name="twitter:image" content="{{ product.coverImage.url | escape_attr }}">
  {% elsif blogPost and blogPost.coverImage %}
    <meta property="og:image" content="{{ blogPost.coverImage.url | escape_attr }}">
    <meta name="twitter:image" content="{{ blogPost.coverImage.url | escape_attr }}">
  {% elsif page and page.coverImage %}
    <meta property="og:image" content="{{ page.coverImage.url | escape_attr }}">
    <meta name="twitter:image" content="{{ page.coverImage.url | escape_attr }}">
  {% endif %}
  {% assign body_font = settings.type_body_font %}
  {% assign body_font_bold = body_font | font_modify: 'weight', 'bold' %}
  {% assign body_font_italic = body_font | font_modify: 'style', 'italic' %}
  {% assign heading_font = settings.type_heading_font | default: body_font %}
  {% assign heading_font_bold = heading_font | font_modify: 'weight', 'bold' | default: heading_font %}
  {% assign heading_font_italic = heading_font | font_modify: 'style', 'italic' %}
  {% assign theme_rounding = settings.theme_rounding | default: 'mediano' %}
  {% assign radius_button = 'var(--radius-xl)' %}
  {% assign radius_card_media = 'var(--radius-2xl)' %}
  {% assign radius_gallery_media = 'var(--radius-3xl)' %}
  {% case theme_rounding %}
    {% when 'ninguno' %}
      {% assign radius_button = '0px' %}
      {% assign radius_card_media = '0px' %}
      {% assign radius_gallery_media = '0px' %}
    {% when 'pequeno' %}
      {% assign radius_button = 'var(--radius-lg)' %}
      {% assign radius_card_media = 'var(--radius-xl)' %}
      {% assign radius_gallery_media = 'var(--radius-2xl)' %}
    {% when 'grande' %}
      {% assign radius_button = '14px' %}
      {% assign radius_card_media = 'var(--radius-3xl)' %}
      {% assign radius_gallery_media = '1.75rem' %}
    {% when 'extra_grande' %}
      {% assign radius_button = 'var(--radius-2xl)' %}
      {% assign radius_card_media = '1.75rem' %}
      {% assign radius_gallery_media = '2.25rem' %}
  {% endcase %}
  {% if body_font and body_font.system? != true %}
    <link
      rel="preload"
      as="font"
      href="{{ body_font | font_url }}"
      type="font/{{ body_font.format | default: 'woff2' }}"
      crossorigin
      fetchpriority="low"
    >
  {% endif %}
  {% if heading_font and heading_font.system? != true and heading_font.picker_value != body_font.picker_value %}
    <link
      rel="preload"
      as="font"
      href="{{ heading_font | font_url }}"
      type="font/{{ heading_font.format | default: 'woff2' }}"
      crossorigin
      fetchpriority="low"
    >
  {% endif %}
  <link rel="icon" href="{{ 'favicon.svg' | asset_url }}" type="image/svg+xml">
  <link rel="canonical" href="{{ canonical_url }}">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <style>
    {% if body_font %}
      {{ body_font | font_face: font_display: 'swap' }}
    {% endif %}
    {% if body_font_bold %}
      {{ body_font_bold | font_face: font_display: 'swap' }}
    {% endif %}
    {% if body_font_italic %}
      {{ body_font_italic | font_face: font_display: 'swap' }}
    {% endif %}
    {% if heading_font and heading_font.picker_value != body_font.picker_value %}
      {{ heading_font | font_face: font_display: 'swap' }}
    {% endif %}
    {% if heading_font_bold and heading_font_bold.picker_value != body_font_bold.picker_value %}
      {{ heading_font_bold | font_face: font_display: 'swap' }}
    {% endif %}
    {% if heading_font_italic and heading_font_italic.picker_value != body_font_italic.picker_value %}
      {{ heading_font_italic | font_face: font_display: 'swap' }}
    {% endif %}

    :root {
      --font-body-family: {{ body_font.family | json | default: '"Inter"' }}, {{ body_font.fallback_families | default: 'sans-serif' }};
      --font-body-style: {{ body_font.style | default: 'normal' }};
      --font-body-weight: {{ body_font.weight | default: 400 }};
      --font-heading-family: {{ heading_font.family | default: body_font.family | default: 'Inter' | json }}, {{ heading_font.fallback_families | default: body_font.fallback_families | default: 'sans-serif' }};
      --font-heading-style: {{ heading_font.style | default: body_font.style | default: 'normal' }};
      --font-heading-weight: {{ heading_font.weight | default: body_font.weight | default: 400 }};
      --color-primary: {{ settings.color_primary | default: '#2563eb' }};
      --color-background: {{ settings.color_background | default: '#ffffff' }};
      --color-text: {{ settings.color_text | default: '#1a1a1a' }};
      --color-text-light: {{ settings.color_text_light | default: '#6b7280' }};
      --theme-radius-button: {{ radius_button }};
      --theme-radius-card-media: {{ radius_card_media }};
      --theme-radius-gallery-media: {{ radius_gallery_media }};
    }

    body {
      font-family: var(--font-body-family);
      font-style: var(--font-body-style);
      font-weight: var(--font-body-weight);
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family: var(--font-heading-family);
      font-style: var(--font-heading-style);
      font-weight: var(--font-heading-weight);
    }
  </style>
  {{ content_for_header }}
</head>
<body class="bg-[var(--color-background)] text-[var(--color-text)] antialiased">
  {% sections 'header-group' %}

  <main>
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% if tracking_enabled %}
    {{ meta_tracking_script }}
    {{ meta_tracking_noscript }}
    {{ google_tracking_script }}
  {% endif %}
  <style>
    .tiendu-editor-hovered {
      outline: 2px solid blue;
      outline-offset: -2px;
    }

    .tiendu-editor-selected {
      outline: 2px solid blue;
      outline-offset: -2px;
    }
  </style>
  <script>
    (function() {
      var hoverTarget = null;
      var selectedTarget = null;
      var hoverElement = null;
      var selectedElement = null;

      function targetsMatch(a, b) {
        return !!a && !!b && a.targetType === b.targetType && a.id === b.id && a.sectionId === b.sectionId;
      }

      function locateTarget(target) {
        if (!target || !target.id) return null;

        if (target.targetType === 'section') {
          return document.querySelector('[data-section-id="' + target.id + '"]');
        }

        if (target.targetType === 'block') {
          var blockSelector = '[data-tiendu-block-id="' + target.id + '"]';
          if (target.sectionId) {
            var sectionRoot = document.querySelector('[data-section-id="' + target.sectionId + '"]');
            if (sectionRoot) return sectionRoot.querySelector(blockSelector);
          }
          return document.querySelector(blockSelector);
        }

        return null;
      }

      function removeHighlightClass(element, className) {
        if (!element) return;
        element.classList.remove(className);
      }

      function addHighlightClass(element, className) {
        if (!element) return;
        element.classList.add(className);
      }

      function updateHighlightState() {
        var nextSelectedElement = locateTarget(selectedTarget);
        var nextHoverElement = locateTarget(hoverTarget);

        if (selectedElement && selectedElement !== nextSelectedElement) {
          removeHighlightClass(selectedElement, 'tiendu-editor-selected');
        }

        if (
          hoverElement &&
          (hoverElement !== nextHoverElement || hoverElement === nextSelectedElement)
        ) {
          removeHighlightClass(hoverElement, 'tiendu-editor-hovered');
        }

        if (nextSelectedElement) {
          addHighlightClass(nextSelectedElement, 'tiendu-editor-selected');
        }

        if (nextHoverElement && !targetsMatch(hoverTarget, selectedTarget)) {
          addHighlightClass(nextHoverElement, 'tiendu-editor-hovered');
        }

        if (nextHoverElement && nextHoverElement === nextSelectedElement) {
          removeHighlightClass(nextHoverElement, 'tiendu-editor-hovered');
        }

        selectedElement = nextSelectedElement;
        hoverElement = targetsMatch(hoverTarget, selectedTarget)
          ? null
          : nextHoverElement;
      }

      window.addEventListener('message', function(e) {
        if (!e.data) return;

        if (e.data.type === 'section:update') {
          var el = document.querySelector('[data-section-id="' + e.data.sectionId + '"]');
          if (!el) return;
          el.outerHTML = e.data.html;
          window.dispatchEvent(new CustomEvent('tiendu:section-updated', {
            detail: { sectionId: e.data.sectionId }
          }));
          updateHighlightState();
          return;
        }

        if (e.data.type === 'theme:css-vars') {
          var vars = e.data.vars;
          for (var key in vars) {
            document.documentElement.style.setProperty(key, vars[key]);
          }
          return;
        }

        if (e.data.type === 'editor:highlight-targets') {
          hoverTarget = e.data.hoverTarget || null;
          selectedTarget = e.data.selectedTarget || null;
          updateHighlightState();
        }
      });

      window.addEventListener('resize', updateHighlightState);
      window.addEventListener('scroll', updateHighlightState, { passive: true });
      window.addEventListener('tiendu:section-updated', updateHighlightState);
      document.addEventListener('DOMContentLoaded', updateHighlightState);
    })();
  </script>
</body>
</html>
