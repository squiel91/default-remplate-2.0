<section class="main-search py-12 md:py-16">
  <div class="container">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">{{ section.settings.title }}</h1>
    <button type="button" class="search-form radius-button mt-6 flex w-full items-center gap-3 border border-slate-300 bg-white px-5 py-3 text-left text-base transition hover:border-slate-400" data-header-search-trigger{% if search.terms != blank %} data-header-search-query="{{ search.terms | escape_attr }}"{% endif %}>
      <span class="inline-flex h-[18px] w-[18px] shrink-0 items-center justify-center text-slate-400">
        {% render 'icon-search', size: 18 %}
      </span>
      {% if search.terms != blank %}
        <span class="truncate text-slate-950">{{ search.terms | escape }}</span>
      {% else %}
        <span class="truncate text-slate-500">Buscar productos...</span>
      {% endif %}
    </button>
    {% if search.performed %}
      {% paginate search.results by section.settings.results_per_page %}
        {% if search.results_count > 0 %}
          <p class="search-count mt-4 text-sm text-[var(--color-text-light)]">{{ paginate.items }} resultado{% if paginate.items != 1 %}s{% endif %} para "{{ search.terms }}"</p>
          <div class="product-grid mt-8 grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-6">
            {% for product in search.results %}
              {% render 'product-card', product: product %}
            {% endfor %}
          </div>
          {% if paginate.pages > 1 %}
            <nav class="pagination">
              {{ paginate | default_pagination }}
            </nav>
          {% endif %}
        {% else %}
          <p class="search-empty py-12 text-center text-base text-[var(--color-text-light)]">No encontramos resultados para "{{ search.terms }}"</p>
        {% endif %}
      {% endpaginate %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Busqueda",
  "enabled_on": {
    "templates": ["search"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Buscar"
    },
    {
      "type": "number",
      "id": "results_per_page",
      "label": "Resultados por pagina",
      "default": 12
    }
  ]
}
{% endschema %}
