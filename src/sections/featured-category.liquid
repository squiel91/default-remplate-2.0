{% assign featured_collection = section.settings.collection %}
<section class="featured-category py-12 md:py-16">
  {% if featured_collection and featured_collection.id %}
    <div class="flex items-center justify-between gap-4 px-4 md:px-6">
      {% if section.settings.title != blank %}
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.title | escape }}</h2>
      {% else %}
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ featured_collection.name | escape }}</h2>
      {% endif %}

      <a href="{{ featured_collection.url }}" class="inline-flex shrink-0 items-center text-sm font-semibold text-[var(--color-primary)] no-underline transition hover:opacity-80">Ver mas</a>
    </div>

    {% paginate featured_collection.products by section.settings.limit %}
      {% render 'product-listing-grid', products: featured_collection.products %}
    {% endpaginate %}
  {% else %}
    <div class="px-4 text-center text-[var(--color-text-light)] md:px-6">
      Selecciona una coleccion para mostrar esta seccion.
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Coleccion destacada",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleccion",
      "default": "alimentos"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Cantidad a mostrar",
      "default": 4
    }
  ]
}
{% endschema %}
