{% assign featured_category_handle = section.settings.category_handle | default: 'alimentos' %}
{% categories handle: featured_category_handle as: 'featured_category' %}
<section class="featured-category py-12 md:py-16">
  {% if featured_category and featured_category.id %}
    <div class="flex items-center justify-between gap-4 px-4 md:px-6">
      {% if section.settings.title != blank %}
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.title | escape }}</h2>
      {% else %}
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ featured_category.name | escape }}</h2>
      {% endif %}

      <a href="{{ featured_category.url }}" class="inline-flex shrink-0 items-center text-sm font-semibold text-[var(--color-primary)] no-underline transition hover:opacity-80">Ver mas</a>
    </div>

    {% products category_id: featured_category.id, limit: section.settings.limit, include_products_from_subcategories: true %}
      {% render 'product-listing-grid', products: products %}
    {% endproducts %}
  {% else %}
    <div class="px-4 text-center text-[var(--color-text-light)] md:px-6">
      Selecciona una categoria para mostrar esta seccion.
    </div>
  {% endif %}
</section>
{% endcategories %}

{% schema %}
{
  "name": "Categoria destacada",
  "settings": [
    {
      "type": "category",
      "id": "category_handle",
      "label": "Categoria",
      "default": "alimentos"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Cantidad de productos",
      "default": 4
    }
  ]
}
{% endschema %}
