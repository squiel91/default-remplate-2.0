<footer class="footer mt-12 border-t border-slate-200 bg-slate-50/80">
  <div class="footer__inner container py-10">
    {% if section.blocks and section.blocks.size > 0 %}
      <div class="footer__grid">
        <div class="footer__column footer__brand">
          <strong class="text-lg font-semibold tracking-tight">{{ store.name }}</strong>
          {% if store.description %}
            <p class="max-w-sm text-sm leading-6 text-[var(--color-text-light)]">{{ store.description }}</p>
          {% endif %}

          {% if store.email_address or store.whatsapp_number %}
            <div class="footer__meta text-sm text-[var(--color-text-light)]">
              {% if store.email_address %}
                <p><a href="mailto:{{ store.email_address }}">{{ store.email_address }}</a></p>
              {% endif %}
              {% if store.whatsapp_number %}
                <p><a href="https://wa.me/{{ store.whatsapp_number }}">WhatsApp</a></p>
              {% endif %}
            </div>
          {% endif %}
        </div>

        {% content_for 'blocks' %}
      </div>
    {% else %}
      <div class="footer__grid footer__grid--legacy">
        <div class="footer__column footer__brand">
          <strong class="text-lg font-semibold tracking-tight">{{ store.name }}</strong>
          {% if store.description %}
            <p class="max-w-sm text-sm leading-6 text-[var(--color-text-light)]">{{ store.description }}</p>
          {% endif %}
        </div>
        <div class="footer__column footer__links">
          <h4 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Paginas</h4>
          {% if section.settings.pages != blank and section.settings.pages.size > 0 %}
            <ul class="space-y-2 text-sm text-[var(--color-text-light)]">
              {% for p in section.settings.pages %}
                <li><a href="{{ p.url }}">{{ p.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
        <div class="footer__column footer__contact text-sm text-[var(--color-text-light)]">
          {% if store.email_address %}
            <p><a href="mailto:{{ store.email_address }}">{{ store.email_address }}</a></p>
          {% endif %}
          {% if store.whatsapp_number %}
            <p><a href="https://wa.me/{{ store.whatsapp_number }}">WhatsApp</a></p>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
  <div class="footer__bottom container flex flex-col gap-2 border-t border-slate-200 py-4 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ store.name }}. Todos los derechos reservados.</p>
    {% if section.settings.copyright_text != blank %}
      <p>{{ section.settings.copyright_text }}</p>
    {% endif %}
  </div>
</footer>

{% schema %}
{
  "name": "Pie de pagina",
  "enabled_on": {
    "groups": ["footer"]
  },
  "max_blocks": 8,
  "settings": [
    {
      "type": "page_list",
      "id": "pages",
      "label": "Paginas"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Texto adicional de copyright",
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "text-column"
    },
    {
      "type": "image-column"
    },
    {
      "type": "collection-menu"
    }
  ]
}
{% endschema %}
