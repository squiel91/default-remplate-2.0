{% assign reviews_count = product.reviewsQuantity | default: 0 %}
{% assign average_rating = product.averageRating | default: 0 %}

<section class="product-reviews border-t border-slate-200 py-12 md:py-16" aria-labelledby="product-reviews-title">
  <div class="container">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h2 id="product-reviews-title" class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
        {{ section.settings.title | default: 'Reseñas' | escape }}
      </h2>
      <span class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-sm font-semibold text-emerald-700">
        {% render 'icon-shield-check', size: 14 %}
        Verificadas por Tiendu
      </span>
    </div>

    <div class="mt-8 grid gap-6 rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_12px_30px_rgba(15,23,42,0.06)] lg:grid-cols-[220px_minmax(0,1fr)]">
      <div class="grid content-start gap-2">
        <strong class="text-5xl font-black leading-none tracking-tight text-slate-950 sm:text-6xl">{{ average_rating | round: 1 }}</strong>
        {% render 'rating-stars', rating: average_rating, size: 30, empty_class: 'text-slate-200', filled_class: 'text-amber-400' %}
        <span class="text-sm text-slate-500">{{ reviews_count }} {% if reviews_count == 1 %}reseña{% else %}reseñas{% endif %}</span>
      </div>

      <div class="grid gap-2">
        {% for score in (1..5) reversed %}
          {% assign review_count = 0 %}
          {% for review in product_page.reviews %}
            {% if review.rating == score %}
              {% assign review_count = review_count | plus: 1 %}
            {% endif %}
          {% endfor %}
          {% assign review_percent = 0 %}
          {% if product_page.reviews.size > 0 %}
            {% assign review_percent = review_count | times: 100.0 | divided_by: product_page.reviews.size %}
          {% endif %}
          <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 text-sm text-slate-600">
            <span>{{ score }} {% if score == 1 %}estrella{% else %}estrellas{% endif %}</span>
            <div class="h-2 overflow-hidden rounded-full bg-slate-200">
              <div class="h-full rounded-full bg-amber-400" style="width: {{ review_percent }}%;"></div>
            </div>
            <strong class="text-slate-950">{{ review_count }}</strong>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="mt-8 grid gap-0">
      {% if product_page.reviews.size > 0 %}
        {% for review in product_page.reviews %}
          <article class="grid gap-3 border-b border-slate-200 py-4">
            <header class="flex flex-wrap items-start justify-between gap-3">
              <div class="grid gap-1">
                <div class="inline-flex flex-wrap items-center gap-2">
                  <h3 class="text-base font-bold leading-5 text-slate-950">{{ review.authorName | default: 'Cliente' | escape }}</h3>
                  {% if review.isVerifiedPurchase %}
                    <span class="inline-flex items-center gap-1 rounded-full border border-emerald-200 bg-emerald-50 px-2 py-1 text-xs font-semibold text-emerald-700">Compra verificada</span>
                  {% endif %}
                </div>
                <p class="text-sm text-slate-400">{{ review.relativeTime | escape }}</p>
              </div>
              {% render 'rating-stars', rating: review.rating, size: 22, empty_class: 'text-slate-200', filled_class: 'text-amber-400' %}
            </header>
            <p class="max-w-3xl text-base leading-7 text-slate-700">{{ review.content | escape }}</p>
          </article>
        {% endfor %}
      {% else %}
        <div class="flex min-h-40 items-center justify-center border-b border-slate-200 py-8 text-center text-slate-500">
          Este producto aun no tiene reseñas.
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reseñas de producto",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Reseñas"
    }
  ]
}
{% endschema %}
