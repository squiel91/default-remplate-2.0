<section class="main-list-collections py-12 md:py-16">
  <div class="container">
    {% if section.settings.title != blank %}
      <h1 class="text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">{{ section.settings.title }}</h1>
    {% endif %}

	    {% if collections != blank %}
	      <div class="collection-grid mt-8 grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-6">
	        {% for collection in collections %}
	          {% assign collection_href = collection.url | append: '?url-from=%2Fcategorias&title-from=Colecciones' %}
	          <a href="{{ collection_href }}" class="collection-card block rounded-3xl border border-slate-200 bg-white p-6 text-center shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:no-underline hover:shadow-md">
            {% if section.settings.show_image and collection.coverImage %}
              <img class="mb-4 aspect-square w-full rounded-2xl object-cover" src="{{ collection.coverImage.url }}" alt="{{ collection.coverImage.alt | default: collection.name }}" loading="lazy">
            {% endif %}

            <h2 class="text-lg font-semibold text-slate-950">{{ collection.name }}</h2>

            {% if section.settings.show_description and collection.description != blank %}
              <p class="mt-2 text-sm leading-6 text-[var(--color-text-light)]">{{ collection.description }}</p>
            {% endif %}

            {% if section.settings.show_product_count %}
              <p class="mt-3 text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-text-light)]">
                {{ collection.productCount }} productos
              </p>
            {% endif %}
          </a>
        {% endfor %}
	      </div>
	    {% else %}
	      <p class="mt-6 text-sm leading-6 text-[var(--color-text-light)]">Aun no hay colecciones publicas para mostrar.</p>
	    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Lista principal de colecciones",
  "enabled_on": {
    "templates": ["list-collections"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Colecciones"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Mostrar imagen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Mostrar descripcion",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Mostrar cantidad de productos",
      "default": false
    }
  ]
}
{% endschema %}
