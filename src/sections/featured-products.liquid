<section class="featured-products py-12 md:py-16">
  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.title }}</h2>
    {% endif %}
    {% products limit: section.settings.limit, sort: 'sales', order: 'desc' %}
      <div class="product-grid mt-6 grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-6">
        {% for product in products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
    {% endproducts %}
  </div>
</section>

{% schema %}
{
  "name": "Productos destacados",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Productos destacados"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Cantidad de productos",
      "default": 8
    }
  ]
}
{% endschema %}
