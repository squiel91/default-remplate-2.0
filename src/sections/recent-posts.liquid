<section class="recent-posts py-12 md:py-16">
  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.title }}</h2>
    {% endif %}
    {% blog_posts limit: section.settings.limit %}
      <div class="post-grid mt-6 grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6">
        {% for post in blog_posts %}
          <article class="post-card overflow-hidden rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
            {% if post.coverImage %}
              <a href="{{ post.url }}">
                <img class="aspect-[16/9] w-full rounded-2xl object-cover" src="{{ post.coverImage.url }}" alt="{{ post.coverImage.alt | default: post.title }}" loading="lazy">
              </a>
            {% endif %}
            <h3 class="mt-4 text-lg font-semibold text-slate-950"><a href="{{ post.url }}">{{ post.title }}</a></h3>
            {% if post.excerpt != blank %}
              <p class="mt-2 text-sm leading-6 text-[var(--color-text-light)]">{{ post.excerpt }}</p>
            {% endif %}
            <time class="mt-3 block text-xs font-medium uppercase tracking-[0.14em] text-slate-400" datetime="{{ post.createdAt }}">{{ post.createdAt | date: '%d/%m/%Y' }}</time>
          </article>
        {% endfor %}
      </div>
    {% endblog_posts %}
  </div>
</section>

{% schema %}
{
  "name": "Posts recientes",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Del blog"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Cantidad de posts",
      "default": 3
    }
  ]
}
{% endschema %}
