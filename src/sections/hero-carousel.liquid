<section class="relative min-h-[520px] w-full select-none overflow-hidden bg-[#dddaca] text-white md:min-h-[620px]" data-hero-carousel data-autoplay-interval="5000">
  {% if section.blocks and section.blocks.size > 0 %}
    <div class="h-full min-h-[inherit]">
      <div class="h-full min-h-[inherit]">
        <div class="h-full min-h-[inherit] select-none overflow-hidden [touch-action:pan-y]" data-role="viewport" data-dragging="false">
          <div class="flex h-full min-h-[inherit] will-change-transform" data-role="track">
            {% content_for 'blocks' %}
          </div>
        </div>

        <div class="absolute bottom-3 left-1/2 z-[2] inline-flex -translate-x-1/2 items-center gap-2 max-md:bottom-3" data-role="hero-controls" aria-label="Controles del carrusel principal">
          <button class="inline-flex h-6 w-6 items-center justify-center border-0 bg-transparent p-0 text-white/80 transition hover:text-white disabled:opacity-40" type="button" data-role="prev-image" aria-label="Slide anterior"{% if section.blocks.size <= 1 %} hidden{% endif %}>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
          </button>

          <div class="inline-flex items-center gap-1.5" data-role="dots" role="tablist" aria-label="Slides del hero"{% if section.blocks.size <= 1 %} hidden{% endif %}>
            {% for block in section.blocks %}
              <button class="tiendu-carousel__dot h-2 w-2 rounded-full border border-transparent bg-white/50 p-0 transition-transform{% if forloop.first %} is-active{% endif %}" type="button" data-dot-index="{{ forloop.index0 }}" role="tab" aria-label="Ir al slide {{ forloop.index }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"></button>
            {% endfor %}
          </div>

          <button class="inline-flex h-6 w-6 items-center justify-center border-0 bg-transparent p-0 text-white/80 transition hover:text-white disabled:opacity-40" type="button" data-role="next-image" aria-label="Slide siguiente"{% if section.blocks.size <= 1 %} hidden{% endif %}>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
          </button>
        </div>
      </div>
    </div>
  {% else %}
    <div class="bg-slate-100 py-16 text-slate-900">
      <div class="container text-center">
        <h2 class="text-2xl font-semibold tracking-tight">Hero Carousel</h2>
        <p class="mt-2 text-[var(--color-text-light)]">Agrega slides a esta seccion desde el editor.</p>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Hero Carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "slide"
    }
  ]
}
{% endschema %}
