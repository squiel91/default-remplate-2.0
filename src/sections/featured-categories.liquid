<section class="featured-categories py-12 md:py-16">
  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.title }}</h2>
    {% endif %}
    {% categories %}
      <div class="category-grid mt-6 grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-6">
        {% for cat in categories %}
          {% assign category_href = cat.url | append: '?url-from=%2F&title-from=Inicio' %}
          <a href="{{ category_href }}" class="category-card block rounded-3xl border border-slate-200 bg-white p-6 text-center shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:no-underline hover:shadow-md">
            {% if cat.coverImage %}
              <img class="mb-4 aspect-square w-full rounded-2xl object-cover" src="{{ cat.coverImage.url }}" alt="{{ cat.coverImage.alt | default: cat.name }}" loading="lazy">
            {% endif %}
            <h3 class="text-lg font-semibold text-slate-950">{{ cat.name }}</h3>
            {% if cat.description != blank %}
              <p class="mt-2 text-sm leading-6 text-[var(--color-text-light)]">{{ cat.description }}</p>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endcategories %}
  </div>
</section>

{% schema %}
{
  "name": "Categorias destacadas",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Nuestras categorias"
    }
  ]
}
{% endschema %}
