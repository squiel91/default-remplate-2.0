<section class="main-blog py-12 md:py-16">
  <div class="container">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">{{ section.settings.title }}</h1>
    {% if blog.articles_count > 0 %}
      <div class="post-grid mt-8 grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6">
        {% for post in blog.articles %}
          {% assign article_href = post.url | append: '?url-from=%2Fblog&title-from=Blog' %}
          <article class="post-card overflow-hidden rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
            {% if post.coverImage %}
              <a href="{{ article_href }}">
                <img class="aspect-[16/9] w-full rounded-2xl object-cover" src="{{ post.coverImage.url }}" alt="{{ post.coverImage.alt | default: post.title }}" loading="lazy">
              </a>
            {% endif %}
            <h3 class="mt-4 text-lg font-semibold text-slate-950"><a href="{{ article_href }}">{{ post.title }}</a></h3>
            {% if post.excerpt != blank %}
              <p class="mt-2 text-sm leading-6 text-[var(--color-text-light)]">{{ post.excerpt }}</p>
            {% endif %}
            <time class="mt-3 block text-xs font-medium uppercase tracking-[0.14em] text-slate-400" datetime="{{ post.createdAt }}">{{ post.createdAt | date: '%d/%m/%Y' }}</time>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "enabled_on": {
    "templates": ["blog"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Blog"
    }
  ]
}
{% endschema %}
