<section class="related-products py-12 md:py-16 [&_.product-card__image]:rounded-2xl">
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="pb-5">
        <h2 class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">{{ section.settings.title }}</h2>
      </div>
    {% endif %}
    {% if product and product.id %}
      {% paginate product.related_products by section.settings.limit %}
        {% if product.related_products_count > 0 %}
          {% render 'product-listing-grid', products: product.related_products, no_padding: true %}
        {% endif %}
      {% endpaginate %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Productos relacionados",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Tambien te puede interesar"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Cantidad",
      "default": 4
    }
  ]
}
{% endschema %}
