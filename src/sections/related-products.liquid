<section class="related-products py-12 md:py-16 [&_.product-card__image]:rounded-2xl">
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="pb-5">
        <h2 class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">{{ section.settings.title }}</h2>
      </div>
    {% endif %}
    {% if product %}
      {% products related_to_product_id: product.id, limit: section.settings.limit %}
        {% render 'product-listing-grid', products: products, no_padding: true %}
      {% endproducts %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Productos relacionados",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Tambien te puede interesar"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Cantidad",
      "default": 4
    }
  ]
}
{% endschema %}
