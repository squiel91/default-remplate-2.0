<section class="related-products py-12 md:py-16">
  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.title }}</h2>
    {% endif %}
    {% if product %}
      {% products limit: section.settings.limit, sort: 'sales', order: 'desc' %}
        <div class="product-grid mt-6 grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-6">
          {% for p in products %}
            {% if p.id != product.id %}
              {% render 'product-card', product: p %}
            {% endif %}
          {% endfor %}
        </div>
      {% endproducts %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Productos relacionados",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Tambien te puede interesar"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Cantidad",
      "default": 4
    }
  ]
}
{% endschema %}
