<section class="main-product" data-currency-code="{{ store.currency.code | default: 'UYU' | escape_attr }}">
  <div class="container">
    <article id="product" class="pb-8 pt-2" aria-live="polite">
      <div class="grid gap-8 py-8 lg:grid-cols-[minmax(400px,1.2fr)_1fr]">
        <div class="flex flex-col gap-4">
          <div class="grid gap-4" id="product-gallery" data-product-gallery>
            <div class="relative">
              <div class="tiendu-carousel__viewport group relative aspect-square overflow-hidden rounded-3xl bg-slate-100 shadow-[0_18px_40px_rgba(15,23,42,0.12)] [touch-action:pan-y] select-none data-[dragging=false]:cursor-grab data-[dragging=true]:cursor-grabbing" data-role="viewport" data-dragging="false">
                <div class="flex h-full will-change-transform" data-role="track">
                  {% for image in product_page.gallery_images %}
                    <div class="block h-full basis-full shrink-0" data-product-gallery-slide{% if image.id != blank %} data-image-id="{{ image.id }}"{% endif %}>
                      <img class="h-full w-full object-cover select-none" src="{{ image.url | escape_attr }}" alt="{{ image.alt | default: product.title | escape_attr }}" {% if forloop.first %}fetchpriority="high" loading="eager"{% else %}loading="lazy"{% endif %}>
                    </div>
                  {% endfor %}
                </div>
                <button class="absolute inset-0 border-0 bg-transparent p-0" type="button" data-role="open-lightbox" aria-label="Ampliar imagen">
                  <span class="pointer-events-none absolute right-3 top-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white text-slate-900 opacity-0 shadow-[0_10px_24px_rgba(15,23,42,0.14)] transition-opacity group-hover:opacity-100 group-focus-within:opacity-100" aria-hidden="true">
                    <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                  </span>
                </button>
              </div>
              <button class="absolute left-3 top-1/2 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border-0 bg-white text-slate-900 shadow-[0_10px_24px_rgba(15,23,42,0.14)] disabled:cursor-not-allowed disabled:opacity-45" type="button" data-role="prev-image" aria-label="Imagen anterior"{% if product_page.gallery_images.size <= 1 %} hidden{% endif %}>
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
              </button>
              <button class="absolute right-3 top-1/2 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border-0 bg-white text-slate-900 shadow-[0_10px_24px_rgba(15,23,42,0.14)] disabled:cursor-not-allowed disabled:opacity-45" type="button" data-role="next-image" aria-label="Imagen siguiente"{% if product_page.gallery_images.size <= 1 %} hidden{% endif %}>
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
              </button>
            </div>

            <div class="flex flex-wrap gap-3 max-md:hidden" data-role="thumbs" aria-label="Selector de imagenes"{% if product_page.gallery_images.size <= 1 %} hidden{% endif %}>
              {% for image in product_page.gallery_images %}
                <button class="tiendu-carousel__thumb h-[72px] w-[72px] cursor-pointer overflow-hidden rounded-2xl border-2 border-transparent bg-white transition-colors hover:border-slate-300" type="button" data-thumb-index="{{ forloop.index0 }}"{% if image.id != blank %} data-image-id="{{ image.id }}"{% endif %} aria-current="{% if forloop.first %}true{% else %}false{% endif %}" aria-label="Ver imagen {{ forloop.index }}">
                  <img class="h-full w-full object-cover" src="{{ image.url | escape_attr }}" alt="{{ image.alt | default: product.title | escape_attr }}" loading="lazy">
                </button>
              {% endfor %}
            </div>
          </div>

          <div class="fixed inset-0 z-50 bg-slate-950/70 backdrop-blur-[6px]" id="product-gallery-lightbox" data-product-gallery-lightbox hidden>
            <div class="absolute inset-0" data-role="backdrop"></div>
            <div class="relative z-10 grid h-full w-full place-items-center p-4" data-role="content">
              <button class="absolute right-3 top-3 inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-slate-900/60 text-slate-50" type="button" data-role="close-lightbox" aria-label="Cerrar imagen ampliada">
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 6-12 12"></path><path d="m6 6 12 12"></path></svg>
              </button>
              <img class="max-h-screen max-w-full object-contain" src="{{ product_page.gallery_images.first.url | escape_attr }}" alt="{{ product_page.gallery_images.first.alt | default: product.title | escape_attr }}" loading="eager" data-role="lightbox-image">
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-6 md:mt-4 lg:mt-8">
          <div class="flex flex-col gap-2">
            <h1 class="text-[clamp(1.8rem,5.7vw,2.9rem)] font-extrabold leading-[1.14] tracking-[-0.03em] text-slate-900">{{ product.title | escape }}</h1>
            {% render 'product-rating', rating: product.averageRating, reviews_count: product.reviewsQuantity %}
            {% if product.unitsSold and product.unitsSold > 0 %}
              <p class="inline-flex items-center gap-2 text-sm font-medium text-slate-500">
                <span class="inline-flex text-slate-400" aria-hidden="true">{% render 'icon-package', size: 16 %}</span>
                {{ product.unitsSold }} vendido{% if product.unitsSold != 1 %}s{% endif %}
              </p>
            {% endif %}
          </div>

          <div class="product-price-line flex flex-wrap items-baseline gap-3"{% if product_page.price.price_in_cents == blank %} hidden{% endif %}>
            <span class="product-price text-[1.9rem] font-bold tracking-[-0.02em] text-slate-900" id="product-price">{% if product_page.price.price_is_from %}Desde {% endif %}{{ product_page.price.price_in_cents | money }}</span>
            <span class="product-compare text-[1.9rem] text-slate-400 line-through" id="product-compare"{% if product_page.price.compare_at_price_in_cents == blank %} hidden{% endif %}>{% if product_page.price.compare_is_from %}Desde {% endif %}{{ product_page.price.compare_at_price_in_cents | money }}</span>
          </div>

          <div id="variant-selector" class="grid gap-4 empty:hidden">
            {% for attribute in product.attributes %}
              {% assign selected_value_id = blank %}
              {% assign selected_value_label = 'Selecciona una opción' %}
              {% assign selected_value_color = blank %}
              {% assign selected_value_image_url = blank %}
              {% assign has_selected_value = false %}
              {% assign attribute_id_str = attribute.id | append: '' %}
              {% for selected_attribute in product_page.default_attribute_values %}
                {% assign selected_attribute_id_str = selected_attribute.attribute_id | append: '' %}
                {% if selected_attribute_id_str == attribute_id_str %}
                  {% assign selected_value_id = selected_attribute.value_id %}
                  {% assign has_selected_value = true %}
                {% endif %}
              {% endfor %}
              {% if attribute.displayType == 'dropdown' %}
                {% for value in attribute.values %}
                  {% assign selected_value_id_str = selected_value_id | append: '' %}
                  {% assign value_id_str = value.id | append: '' %}
                  {% if has_selected_value and selected_value_id_str == value_id_str %}
                    {% assign selected_value_label = value.value %}
                    {% assign selected_value_color = value.color %}
                    {% if value.image != blank and value.image.url != blank %}
                      {% assign selected_value_image_url = value.image.url %}
                    {% endif %}
                  {% endif %}
                {% endfor %}
                <fieldset class="m-0 flex min-w-0 flex-wrap items-start gap-2 border-0 p-0">
                  <legend class="mb-1 mr-2 text-sm font-semibold text-slate-900">{{ attribute.name | escape }}</legend>
                  <div class="variant-select relative inline-block min-w-56" data-attribute-id="{{ attribute.id }}">
                    <button class="inline-flex h-10 w-full items-center overflow-hidden rounded-[14px] border border-slate-300 bg-white pr-3 text-sm font-semibold text-slate-900 hover:border-slate-400 hover:bg-slate-50" type="button" data-variant-select-trigger aria-haspopup="listbox" aria-expanded="false" aria-label="{{ attribute.name | escape_attr }}">
                      <span class="variant-select__trigger-swatch inline-flex h-10 w-10 shrink-0 overflow-hidden{% if has_selected_value == false or selected_value_image_url == blank and selected_value_color == blank %} variant-select__trigger-swatch--hidden{% endif %}" data-variant-select-trigger-swatch aria-hidden="true">
                        {% if has_selected_value and selected_value_image_url != blank %}
                          <span class="variant-select__swatch inline-flex h-10 w-10 shrink-0 overflow-hidden border-r border-slate-300/45 bg-slate-200"><img class="h-full w-full object-cover" src="{{ selected_value_image_url | escape_attr }}" alt="" loading="lazy"></span>
                        {% elsif has_selected_value and selected_value_color != blank %}
                          <span class="variant-select__swatch inline-flex h-10 w-10 shrink-0 overflow-hidden border-r border-slate-300/45 bg-slate-200" style="background: {{ selected_value_color | escape_attr }};"></span>
                        {% endif %}
                      </span>
                      <span class="variant-select__label flex-1 overflow-hidden px-3 text-left text-ellipsis whitespace-nowrap{% if has_selected_value == false %} variant-select__label--placeholder{% endif %}" data-variant-select-label>{{ selected_value_label | escape }}</span>
                      <svg class="variant-select__chevron h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
                    </button>
                    <div class="variant-select__menu absolute left-0 right-0 top-[calc(100%+0.4rem)] z-20 max-h-60 overflow-auto rounded-xl border border-slate-300 bg-white shadow-[0_10px_20px_rgba(15,23,42,0.08)]" data-variant-select-menu role="listbox" hidden>
                      {% for value in attribute.values %}
                        <button class="variant-select__option flex h-10 w-full items-stretch overflow-hidden border-0 bg-white text-left text-sm font-semibold text-slate-900 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-value-id="{{ value.id }}" data-label="{{ value.value | escape_attr }}"{% if value.color != blank %} data-color="{{ value.color | escape_attr }}"{% endif %}{% if value.image != blank and value.image.url != blank %} data-image-url="{{ value.image.url | escape_attr }}"{% endif %} aria-selected="{% if selected_value_id == value.id %}true{% else %}false{% endif %}">
                          {% if value.image != blank and value.image.url != blank %}
                            <span class="variant-select__swatch inline-flex h-10 w-10 shrink-0 overflow-hidden border-r border-slate-300/45 bg-slate-200"><img class="h-full w-full object-cover" src="{{ value.image.url | escape_attr }}" alt="" loading="lazy"></span>
                          {% elsif value.color != blank %}
                            <span class="variant-select__swatch inline-flex h-10 w-10 shrink-0 overflow-hidden border-r border-slate-300/45 bg-slate-200" style="background: {{ value.color | escape_attr }};" aria-hidden="true"></span>
                          {% endif %}
                          <span class="inline-flex h-full items-center px-3">{{ value.value | escape }}</span>
                        </button>
                      {% endfor %}
                    </div>
                  </div>
                </fieldset>
              {% else %}
                <fieldset class="m-0 flex min-w-0 flex-wrap items-center gap-2 border-0 p-0" data-attribute-name="{{ attribute.name | escape_attr }}">
                  <legend class="mb-1 mr-2 text-sm font-semibold text-slate-900">{{ attribute.name | escape }}</legend>
                  {% for value in attribute.values %}
                    <button type="button" class="option-chip inline-flex h-10 items-center overflow-hidden rounded-[14px] border border-slate-300 bg-white text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-40{% if value.image == blank and value.color == blank %} px-4{% endif %}" data-attribute-id="{{ attribute.id }}" data-value-id="{{ value.id }}" aria-pressed="{% if selected_value_id == value.id %}true{% else %}false{% endif %}">
                      {% if value.image != blank and value.image.url != blank %}
                        <span class="inline-flex h-full w-9 shrink-0 overflow-hidden border-r border-slate-300/45 bg-slate-200" aria-hidden="true"><img class="h-full w-full object-cover" src="{{ value.image.url | escape_attr }}" alt="" loading="lazy"></span>
                      {% elsif value.color != blank %}
                        <span class="inline-flex h-full w-9 shrink-0 overflow-hidden border-r border-slate-300/45 bg-slate-200" style="background: {{ value.color | escape_attr }};" aria-hidden="true"></span>
                      {% endif %}
                      <span class="inline-flex h-full items-center px-3">{{ value.value | escape }}</span>
                    </button>
                  {% endfor %}
                </fieldset>
              {% endif %}
            {% endfor %}
          </div>

          <p id="stock-note" class="product-stock-note inline-flex items-center gap-2 text-[0.95rem] font-semibold leading-[1.35] text-slate-500" data-tone="{{ product_page.stock_note.tone }}">
            <span class="relative inline-grid h-[14px] w-[14px] shrink-0 place-items-center" aria-hidden="true"><span class="product-stock-note__pulse absolute left-1/2 top-1/2 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-current opacity-35"></span><span class="absolute left-1/2 top-1/2 z-[1] h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-current"></span></span>
            <span class="product-stock-note__message">{{ product_page.stock_note.message }}</span>
          </p>

          <div class="grid gap-5">
            <div class="flex w-full items-center gap-3 max-md:flex-col">
              <div id="product-quantity-input" class="inline-flex h-10 shrink-0 items-center overflow-hidden rounded-[14px] border border-slate-300 bg-white max-md:w-full"{% if product_page.quantity_hidden %} hidden{% endif %}>
                <button type="button" class="inline-flex h-10 w-10 items-center justify-center bg-transparent text-[1.1rem] font-bold text-slate-900 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-35" data-quantity-decrease aria-label="Disminuir cantidad">-</button>
                <input class="quantity-input__field h-10 w-12 border-0 bg-transparent p-0 text-center text-[0.95rem] font-bold text-slate-900 outline-none max-md:w-full" type="number" inputmode="numeric" min="1" value="1" {% if product_page.quantity_max != blank %}max="{{ product_page.quantity_max }}"{% endif %} {% if product_page.quantity_disabled %}disabled{% endif %} aria-label="Cantidad">
                <button type="button" class="inline-flex h-10 w-10 items-center justify-center bg-transparent text-[1.1rem] font-bold text-slate-900 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-35" data-quantity-increase aria-label="Aumentar cantidad">+</button>
              </div>
              <button type="button" id="add-to-cart-button" class="w-full flex-1 rounded-full bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-white shadow-[0_14px_30px_rgba(37,99,235,0.25)] transition hover:opacity-90 disabled:cursor-wait disabled:opacity-80" data-icon="{{ product_page.add_to_cart.icon }}" data-loading-icon="loader-2" data-loading-label="Agregando" aria-label="{{ product_page.add_to_cart.label | escape_attr }}" {% if product_page.add_to_cart.disabled %}disabled{% endif %}>
                <span class="inline-flex items-center justify-center gap-2" aria-hidden="true">
                  <span data-button-icon="plus"{% if product_page.add_to_cart.icon != 'plus' %} hidden{% endif %}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg></span>
                  <span data-button-icon="message-square"{% if product_page.add_to_cart.icon != 'message-square' %} hidden{% endif %}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></span>
                  <span data-button-icon="loader-2" hidden><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg></span>
                </span>
                <span class="button__label">{{ product_page.add_to_cart.label }}</span>
              </button>
            </div>

            <ul class="grid gap-3" aria-label="Beneficios de compra">
              <li class="inline-flex items-center gap-2.5 text-sm font-medium text-slate-600">{% render 'icon-truck', size: 16 %}<span>Envío gratis en pedidos superiores a $ 2.000</span></li>
              <li class="inline-flex items-center gap-2.5 text-sm font-medium text-slate-600">{% render 'icon-rotate-ccw', size: 16 %}<span>Devolución simplificada</span></li>
              <li class="inline-flex items-center gap-2.5 text-sm font-medium text-slate-600">{% render 'icon-credit-card', size: 16 %}<span>Pagalo hasta en 12 cuotas sin recargo con tarjeta de crédito</span></li>
            </ul>

            <div class="grid gap-2 sm:grid-cols-2">
              <div class="flex h-12 items-center justify-center rounded-2xl border border-slate-200 bg-white px-4">
                <img src="{{ 'mercadopago.svg' | asset_url }}" alt="Mercado Pago" class="h-7 w-auto" loading="lazy">
              </div>
              <div class="flex h-12 items-center justify-center rounded-2xl border border-slate-200 bg-white px-4">
                <img src="{{ 'visa.svg' | asset_url }}" alt="Visa" class="h-6 w-auto" loading="lazy">
              </div>
              <div class="flex h-12 items-center justify-center rounded-2xl border border-slate-200 bg-white px-4">
                <img src="{{ 'master.svg' | asset_url }}" alt="Mastercard" class="h-6 w-auto" loading="lazy">
              </div>
              <div class="flex h-12 items-center justify-center rounded-2xl border border-slate-200 bg-white px-4">
                <img src="{{ 'oca.svg' | asset_url }}" alt="OCA" class="h-6 w-auto" loading="lazy">
              </div>
            </div>

            <button type="button" class="inline-flex w-fit items-center gap-2 rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950" data-share-product>
              <span class="inline-flex" aria-hidden="true">{% render 'icon-forward', size: 18 %}</span>
              <span data-share-label>Compartir</span>
            </button>
          </div>

        </div>
      </div>
    </article>

    <script id="product-json" type="application/json">{{ product | json }}</script>
  </div>
</section>

{% schema %}
{
  "name": "Producto principal",
  "settings": []
}
{% endschema %}
