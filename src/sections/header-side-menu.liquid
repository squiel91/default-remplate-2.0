<aside class="header-drawer" id="header-side-menu-drawer" data-header-drawer-root data-open="false" aria-hidden="true" aria-label="Menu lateral" role="dialog" aria-modal="true">
  <button type="button" class="header-drawer__backdrop" data-header-drawer-close aria-label="Cerrar menu lateral"></button>

  <div class="header-drawer__panel">
    <div class="header-drawer__header">
      <a href="/" class="header-drawer__logo">{{ store.name }}</a>

      <button type="button" class="header__action-button header-drawer__close radius-button" data-header-drawer-close aria-label="Cerrar menu lateral">
        <span class="header__action-icon" aria-hidden="true">{% render 'icon-x', size: 18 %}</span>
      </button>
    </div>

    <div class="header-drawer__body">
      {% if section.blocks and section.blocks.size > 0 %}
        {% content_for 'blocks' %}
      {% elsif design_mode or preview_mode %}
        <p class="header-drawer__empty">Agrega bloques para construir el menu lateral.</p>
      {% endif %}
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "Menu lateral",
  "enabled_on": {
    "groups": ["header"]
  },
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "menu_item"
    },
    {
      "type": "layout-group"
    },
    {
      "type": "layout-grid"
    },
    {
      "type": "heading"
    },
    {
      "type": "text"
    },
    {
      "type": "link-list"
    },
    {
      "type": "button"
    }
  ],
  "presets": [
    {
      "name": "Menu lateral",
      "blocks": {
        "drawer-shell": {
          "type": "layout-group",
          "settings": {
            "direction_mobile": "column",
            "direction_tablet": "column",
            "direction_desktop": "column",
            "justify_mobile": "flex-start",
            "justify_tablet": "flex-start",
            "justify_desktop": "flex-start"
          },
          "blocks": {
            "drawer-title": {
              "type": "heading",
              "settings": {
                "text": "Menu",
                "tag": "h2",
                "size": "small"
              }
            },
            "drawer-links": {
              "type": "link-list",
              "blocks": {
                "drawer-home": {
                  "type": "link-item",
                  "settings": {
                    "text": "Inicio",
                    "url": "/",
                    "open_in_new_page": false
                  }
                },
                "drawer-collections": {
                  "type": "link-item",
                  "settings": {
                    "text": "Colecciones",
                    "url": "tiendu://collections/todas",
                    "open_in_new_page": false
                  }
                },
                "drawer-blog": {
                  "type": "link-item",
                  "settings": {
                    "text": "Blog",
                    "url": "/blog",
                    "open_in_new_page": false
                  }
                }
              },
              "block_order": ["drawer-home", "drawer-collections", "drawer-blog"]
            }
          },
          "block_order": ["drawer-title", "drawer-links"]
        }
      },
      "block_order": ["drawer-shell"]
    }
  ]
}
{% endschema %}
