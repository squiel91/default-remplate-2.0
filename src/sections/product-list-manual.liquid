<section class="product-list-manual py-12 md:py-16">
  <div class="px-4 md:px-6">
    {% if section.settings.title != blank %}
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.title | escape }}</h2>
    {% endif %}

    {% assign selected_products = section.settings.products %}
    {% if selected_products and selected_products.size > 0 %}
      <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
        {% for product in selected_products %}
          <a href="{{ product.url }}" class="block bg-white no-underline text-slate-950 transition hover:opacity-80">
            {% if product.coverImage and product.coverImage.url %}
              <img
                class="aspect-square w-full bg-slate-100 object-cover"
                src="{{ product.coverImage.url }}"
                alt="{{ product.coverImage.alt | default: product.title }}"
                loading="lazy"
              >
            {% else %}
              <div class="aspect-square w-full bg-slate-100"></div>
            {% endif %}

            <p class="mt-2 text-sm font-medium">{{ product.title | escape }}</p>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="mt-6 text-sm text-slate-500">
        Selecciona productos para mostrar esta seccion.
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Lista manual de productos",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Productos elegidos"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Productos",
      "limit": 8
    }
  ]
}
{% endschema %}
