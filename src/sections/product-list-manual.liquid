{% assign selected_products = section.settings.products %}
{% if selected_products and selected_products.size > 0 %}
  <section class="product-list-manual product-list-section py-12 md:py-16">
    <div class="container">
      {% if section.blocks and section.blocks.size > 0 %}
        <div class="product-list-section__intro">
          {% content_for 'blocks' %}
        </div>
      {% endif %}

      {% render 'product-listing-grid', products: selected_products, no_padding: true %}
    </div>
  </section>
{% elsif design_mode or preview_mode %}
  <section class="product-list-manual product-list-section py-12 md:py-16">
    <div class="container">
      {% if section.blocks and section.blocks.size > 0 %}
        <div class="product-list-section__intro">
          {% content_for 'blocks' %}
        </div>
      {% endif %}

      <div class="product-list-section__empty mt-6">
        Selecciona productos para mostrar esta seccion.
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Lista manual de productos",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 4,
  "settings": [
    {
      "type": "product_list",
      "id": "products",
      "label": "Productos",
      "limit": 8
    }
  ],
  "blocks": [
    {
      "type": "layout-group"
    }
  ],
  "presets": [
    {
      "name": "Lista manual de productos",
      "settings": {
        "products": []
      },
      "blocks": {
        "group": {
          "type": "layout-group",
          "settings": {
            "direction_mobile": "column",
            "direction_tablet": "row",
            "direction_desktop": "row",
            "justify_mobile": "flex-start",
            "justify_tablet": "space-between",
            "justify_desktop": "space-between"
          },
          "blocks": {
            "title": {
              "type": "heading",
              "settings": {
                "text": "Productos elegidos",
                "tag": "h2",
                "size": "medium"
              }
            }
          },
          "block_order": ["title"]
        }
      },
      "block_order": ["group"]
    }
  ]
}
{% endschema %}
