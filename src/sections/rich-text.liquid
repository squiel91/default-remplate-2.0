<section class="rich-text py-12 md:py-16">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <div class="rte mt-6 max-w-none">{{ section.settings.text }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Texto enriquecido",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": ""
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Contenido",
      "default": ""
    }
  ]
}
{% endschema %}
