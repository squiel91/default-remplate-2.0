<section class="not-found py-20">
  <div class="container mx-auto max-w-2xl text-center">
    <h1 class="text-4xl font-semibold tracking-tight text-slate-950">{{ section.settings.heading }}</h1>
    <p class="mt-4 text-lg leading-8 text-[var(--color-text-light)]">{{ section.settings.text }}</p>
    <a href="/" class="mt-8 inline-flex items-center justify-center bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-white no-underline transition hover:opacity-90 radius-button">{{ section.settings.cta_text }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Pagina no encontrada",
  "enabled_on": {
    "templates": ["404"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Pagina no encontrada"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Mensaje",
      "default": "Lo sentimos, no pudimos encontrar la pagina que buscas."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del boton",
      "default": "Volver al inicio"
    }
  ]
}
{% endschema %}
