<section class="collection-list py-12 md:py-16">
  <div class="container">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">{{ section.settings.title }}</h1>
    {% categories %}
      <div class="category-grid mt-8 grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-6">
        {% for cat in categories %}
          {% assign category_href = cat.url | append: '?url-from=%2Fcategorias&title-from=Categorias' %}
          <a href="{{ category_href }}" class="category-card block rounded-3xl border border-slate-200 bg-white p-6 text-center shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:no-underline hover:shadow-md">
            {% if cat.coverImage %}
              <img class="mb-4 aspect-square w-full rounded-2xl object-cover" src="{{ cat.coverImage.url }}" alt="{{ cat.coverImage.alt | default: cat.name }}" loading="lazy">
            {% endif %}
            <h3 class="text-lg font-semibold text-slate-950">{{ cat.name }}</h3>
            {% if cat.description != blank %}
              <p class="mt-2 text-sm leading-6 text-[var(--color-text-light)]">{{ cat.description }}</p>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endcategories %}
  </div>
</section>

{% schema %}
{
  "name": "Lista de categorias",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Categorias"
    }
  ]
}
{% endschema %}
