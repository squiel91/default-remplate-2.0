<div class="product-card">
  <a href="{{ product.url }}" class="group block overflow-hidden rounded-3xl border border-slate-200 bg-white p-3 no-underline shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md">
    {% if product.coverImage %}
      <img class="product-card__image aspect-square w-full rounded-2xl bg-slate-100 object-cover" src="{{ product.coverImage.url }}" alt="{{ product.coverImage.alt | default: product.title }}" loading="lazy">
    {% else %}
      <div class="product-card__image product-card__image--placeholder aspect-square w-full rounded-2xl bg-slate-100"></div>
    {% endif %}
    <h3 class="product-card__name mt-4 text-base font-semibold text-slate-950">{{ product.title }}</h3>
    {% if product.basePriceInCents %}
      <p class="product-card__price mt-2 text-sm font-semibold text-[var(--color-primary)]">{{ product.basePriceInCents | money }}</p>
    {% endif %}
  </a>
</div>
